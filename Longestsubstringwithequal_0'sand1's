#include <iostream>
#include <string>
#include <algorithm> // Required for max and min

using namespace std;

int main() { // 'public' removed
    string s;
    cin >> s;
    
    int z = 0, o = 0, l = 0;
    
    for (int i = 0; i < s.length(); i++) {
        // In C++, use square brackets s[i] instead of s.charAt(i)
        if (s[i] == '0') {
            if (i > 0 && s[i-1] == '1') {
                z = 0;
                o = 0;
            }
            z++;
        } else {
            o++;
            // In C++, use max and min directly from <algorithm> instead of Math.max
            l = max(l, 2 * min(z, o));
        }
    }
    
    cout << l << endl; // Print the result before returning
    return l;
}
